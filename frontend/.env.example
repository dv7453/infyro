# MVP: skip phone/OTP and open the dashboard (uses POST /auth/dev-login).
# Set to 0 for real auth. Requires INFYRO_DEV_MODE=1 on the API when skip-auth is on.
VITE_SKIP_AUTH=1

# Leave empty in local dev (Vite proxies /auth, /agents, … → :8000).
# For production builds, set your public API origin:
# VITE_API_URL=https://your-api.example.com
VITE_API_URL=
