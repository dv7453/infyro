# Postgres
POSTGRES_USER=infyro
POSTGRES_PASSWORD=infyro
POSTGRES_DB=infyro
POSTGRES_PORT=55432
DATABASE_URL=postgresql+psycopg://infyro:infyro@127.0.0.1:55432/infyro

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800
FERNET_KEY=generate-with-python-cryptography-Fernet.generate_key

# Telegram (create via @BotFather — see README)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=InfyroMarketBot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_INGRESS=hermes

# API
API_HOST=0.0.0.0
API_PORT=8000
# Frontend Vite default is 5174
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Optional shared Alpha Vantage
ALPHA_VANTAGE_API_KEY=

# Optional chat model override (production: prefer a stronger Groq model)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional MVP LLM fallback if agent has no BYOK key yet
GROQ_API_KEY=

# Local/MVP: inline OTP + POST /auth/dev-login (never enable in production)
INFYRO_DEV_MODE=1
